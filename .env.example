# ClickSmith — environment variables.
# Copy to `.env.local` for local dev. Set the same keys in Vercel → Settings → Environment Variables for prod.

# ──────────────────────────────────────────────────────────────────────────────
# PUBLIC — safe to expose to browser (NEXT_PUBLIC_ prefix is required)
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://www.clicksmith.com.au"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="clicksmith.com.au"

# ──────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY — never expose to the browser
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (form submissions, playbook purchases, lead data)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Hostinger SMTP (audit form email notifications)
# Get these from Hostinger hPanel > Emails > [your mailbox] > Configuration settings.
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="discover@clicksmith.com.au"
SMTP_PASS=""
SMTP_TO="discover@clicksmith.com.au"

# Resend (future — transactional email for playbook delivery etc.)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="discover@clicksmith.com.au"

# Stripe (playbook purchases — add when playbooks go live)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Cal.com or Calendly (audit bookings)
NEXT_PUBLIC_CALENDAR_URL="https://cal.com/clicksmith/audit"
